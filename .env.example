# Copy to `.env` for local overrides. Never commit real secrets.
#
# Phase L1 — Alembic / sync clients (psycopg v3). Use standard libpq URI; Alembic
# rewrites bare postgresql:// to postgresql+psycopg for SQLAlchemy automatically.
# DATABASE_URL_SYNC=postgresql://deepguard:deepguard@127.0.0.1:5432/deepguard
# If you remap Postgres (DEEPGUARD_POSTGRES_PORT), use that host port in the URL.
#
# Phase L3+ — async app (asyncpg). If unset, API defaults to in-memory scan store.
# DATABASE_URL=postgresql+asyncpg://deepguard:deepguard@127.0.0.1:5432/deepguard
# DEEPGUARD_DEV_TENANT_ID=<uuid from scripts/seed_dev_tenant.py output or tenants table>
# DEEPGUARD_DEV_API_KEY=dev
# Browser dev (Next console on :3000) — comma-separated origins for FastAPI CORS:
# DEEPGUARD_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# DEEPGUARD_L3_MEMORY_STORE=0   # set to 1 to force memory store even when DATABASE_URL is set
#
# Optional Postgres-backed API integration test:
# DEEPGUARD_API_TEST=1
#
# REDIS_URL=redis://127.0.0.1:6379/0
#
# Phase L4 — worker (same DATABASE_URL / REDIS_URL as async API when using Postgres)
# python3 -m deepguard_worker
# DEEPGUARD_WORKER_CONSUMER=worker-1
# DEEPGUARD_WORKER_HEARTBEAT_SEC=30
# DEEPGUARD_WORKER_STUB_ITERATIONS=3
#
# Phase L5 — LangGraph Postgres checkpointer (sync libpq URI; optional dedicated DB)
# CHECKPOINT_DB_URL=postgresql://deepguard:deepguard@127.0.0.1:5432/deepguard
# If you remap Redis (DEEPGUARD_REDIS_PORT), match the host port, e.g.:
# REDIS_URL=redis://127.0.0.1:6380/0
#
# Docker Compose port overrides (repo root `.env`, loaded automatically by compose):
# DEEPGUARD_POSTGRES_PORT=5432
# DEEPGUARD_REDIS_PORT=6379
# DEEPGUARD_MINIO_API_PORT=9000
# DEEPGUARD_MINIO_CONSOLE_PORT=9001
# S3 endpoint for MinIO (SDK-specific; see Architecture §32):
# AWS_ENDPOINT_URL_S3=http://127.0.0.1:9000
# AWS_ACCESS_KEY_ID=deepguard
# AWS_SECRET_ACCESS_KEY=deepguarddev
#
# Hermes ingestion (worker) — opt-in git clone + repo.tar.gz staging to S3/MinIO
# DEEPGUARD_HERMES_ENABLED=1
# DEEPGUARD_REPO_MAX_BYTES=2147483648
# DEEPGUARD_REPO_CLONE_DEPTH=50
# DEEPGUARD_S3_BUCKET=deepguard-dev
# DEEPGUARD_S3_REGION=us-east-1
# DEEPGUARD_S3_ENDPOINT_URL=http://127.0.0.1:9000
# DEEPGUARD_S3_ACCESS_KEY_ID=deepguard
# DEEPGUARD_S3_SECRET_ACCESS_KEY=deepguarddev
#
# API presigned repo uploads (same S3 env vars as worker; US-DG-02-011)
# POST /v1/repo-uploads → 503 if bucket/keys are unset
#
# EPIC-DG-11 — LangSmith (tracing on by default outside CI), LangFuse (self-hosted), OTEL
# LANGSMITH_API_KEY=...          # or LANGCHAIN_API_KEY
# LANGCHAIN_TRACING_V2=true     # default outside CI; set false for air-gap
# DEEPGUARD_AIR_GAP=1            # forces LANGCHAIN_TRACING_V2=false when unset
# LANGFUSE_HOST=http://127.0.0.1:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# DEEPGUARD_OTEL_BOOTSTRAP=1     # default: install console OTEL + FastAPI spans
# DEEPGUARD_OTEL_BOOTSTRAP=0    # pytest / CI default via tests/conftest.py
# Optional LangSmith dataset name for eval stub: LANGSMITH_DATASET_ATHENA_GOLD=...
