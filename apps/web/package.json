{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:e2e:live": "E2E_LIVE_BACKEND=1 playwright test e2e-live-control-plane.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:compose": "E2E_REAL_API=1 playwright test e2e/repo-upload-minio.spec.ts",
    "test:e2e:power-rag": "E2E_POWER_RAG_BACKEND=1 playwright test e2e/bdd-console-power-rag.spec.ts",
    "report:bdd-pdf": "python3 ../../scripts/playwright_bdd_report_to_pdf.py --report-dir playwright-report --output ../../reports/playwright-bdd-report.pdf"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
